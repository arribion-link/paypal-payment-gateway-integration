<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>paypal payment gateway intergration</title>
    <style>
      *{
        padding: 0;
        margin: 0;
        box-sizing: border-box;
      }
      body{
        background-color: gainsboro;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
      }
      .main-container{
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 5em;
      }
      img{
        max-width: 15em;
        border-radius: 10px;
      }
      .product-container{
        margin-top: 2em;
        padding: 5px;
        background-color: aliceblue;
        border-radius: 10px;
        width: fit-content;
        box-shadow: 1px 1px 25px rgb(188, 188, 188);
      }
      .descri-container{
        padding: 12px;
      }
      /* .descri-container h1{
        font-size: medium;
        color: skyblue;
      } */
      button{
        background-color: yellowgreen;
        color: blue;
        font-size: large;
        width: 100%;
        font-weight: 500;
        border: none;
        padding: 5px ;
        margin: 5px 0px;
        border-radius: 5px;
      }
    </style>
</head>
<body>
    <div class="main-container">
        <div>
            <!-- <h1>PAYPAL PAYMENT GATEWAY INTEGRATION</h1> -->
            <div class="product-container">
                <img src="https://placehold.net/book.svg" alt="">
                <div class="descri-container">
                    <div style="display: flex; justify-content: space-between;">
                        <h1>Notebook</h1>
                        <p>Price $<span>100</span></p>
                    </div>
                  <form action="/pay" method="post">
                      <button type="submit">paypal</button>
                  </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>